WORKSPACE_ROOT=/workspaces/DL-MCP
PORT=3544
LOG_LEVEL=info
MAX_FILE_SIZE_MB=5
MAX_HTTP_RESPONSE_MB=2
CORS_ORIGIN=*
IGNORED_PATHS=node_modules,.git,.next,dist,build,coverage,.DS_Store
# AUTH_TOKEN=dl-mcp-dev-token
SEARCH_MAX_DEPTH=12
SEARCH_MAX_FILES=2000
SEARCH_MAX_MATCHES=250
LIST_MAX_DEPTH=3
LIST_MAX_ENTRIES=1000
REQUEST_TIMEOUT_MS=300000
SESSION_IDLE_TIMEOUT_MS=3600000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
ENABLE_TLS=false
TLS_CERT_PATH=
TLS_KEY_PATH=
