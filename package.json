{
  "name": "dl-mcp",
  "version": "1.2.0",
  "description": "Enterprise Filesystem MCP Server — cross-platform binary",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "bundle": "node build.mjs",
    "start": "node dist/index.js",
    "start:bundle": "node dist/bundle.cjs",
    "dev": "tsx watch src/index.ts",
    "pkg:linux": "pkg dist/bundle.cjs --targets node18-linux-x64 --output dist/dl-mcp-linux --compress Brotli",
    "pkg:mac": "pkg dist/bundle.cjs --targets node18-macos-arm64 --output dist/dl-mcp-macos --compress Brotli",
    "pkg:win": "pkg dist/bundle.cjs --targets node18-win-x64 --output dist/dl-mcp-win.exe --compress Brotli",
    "pkg:all": "npm run pkg:linux && npm run pkg:mac && npm run pkg:win",
    "release": "npm run bundle && npm run pkg:all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DevLouix/DL-MCP.git"
  },
  "keywords": [
    "mcp",
    "filesystem",
    "enterprise"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DevLouix/DL-MCP/issues"
  },
  "homepage": "https://github.com/DevLouix/DL-MCP#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.0.0",
    "localtunnel": "^2.0.2",
    "morgan": "^1.10.1",
    "pino": "^9.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "esbuild": "^0.25.2",
    "pkg": "^5.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "pkg": {
    "assets": "dist/bundle.env",
    "compress": "Brotli"
  }
}
